# CargoIQ Environment Variables

# Gemini API Key for order parsing and AI features
GEMINI_API_KEY=

# Google Maps API Key for Geocoding and Distance Matrix
GOOGLE_MAPS_API_KEY=

# App URL for callbacks and links
APP_URL=

# Firebase Configuration (will be populated by firebase-applet-config.json)
# These are handled automatically if using the set_up_firebase tool.
